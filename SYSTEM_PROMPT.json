{
  "meta": {
    "prompt_version": "1.0.0",
    "created": "2026-06-11",
    "purpose": "Emergent-friendly system prompt for AI agents working on the Clinic Management System codebase",
    "usage": "Provide this JSON as system context to any LLM/agent before asking it to read, modify, extend, or debug this codebase"
  },

  "system_identity": {
    "name": "Clinic Management System",
    "version": "1.0.0",
    "domain": "Philippine Healthcare / Clinic Desktop Application",
    "language": "Python 3.10+",
    "ui_framework": "CustomTkinter",
    "database": "MySQL 8.0+ via SQLAlchemy 2.x ORM (PyMySQL driver)",
    "platform": "Windows Desktop (also runnable on Linux/macOS with Python)",
    "entry_point": "main.py",
    "launcher": "clinic.bat (Windows auto-bootstrap)",
    "default_credentials": {
      "username": "admin",
      "password": "admin123"
    }
  },

  "architecture": {
    "pattern": "Layered MVC (Model-View-Controller with Repository pattern)",
    "layers": [
      {
        "name": "Views",
        "path": "views/",
        "role": "Passive UI screens built with CustomTkinter. Views receive injected service references and call them directly on user action.",
        "sub_components": ["views/components/widgets.py", "views/components/theme.py"]
      },
      {
        "name": "Controller",
        "path": "controllers/app_controller.py",
        "role": "Single application facade. Owns the SQLAlchemy session and all service instances. Wires login/logout, DB initialization, and service exposure."
      },
      {
        "name": "Services",
        "path": "services/",
        "role": "Business logic layer. Validates input, applies business rules (discounts, PhilHealth math), writes audit/activity logs, delegates persistence to repositories."
      },
      {
        "name": "Repositories",
        "path": "repositories/",
        "role": "Data-access layer. Encapsulates all SQLAlchemy queries. Extend BaseRepository[ModelType] for generic CRUD."
      },
      {
        "name": "Models",
        "path": "models/",
        "role": "SQLAlchemy ORM declarations. All tables, relationships, and computed properties live here."
      },
      {
        "name": "Database",
        "path": "database/",
        "role": "Engine setup, SessionLocal, Base, init_db(), runtime schema migrations (_migrate_schema)."
      }
    ],
    "data_flow": "User action in View → Service call (injected ref) → Repository query → ORM Model ↔ MySQL",
    "session_model": "Single shared SQLAlchemy Session per AppController instance. Services use session.flush() for intermediate writes; AppController.commit() for final persistence.",
    "auth_model": "In-memory SessionManager singleton (utils/security.py). No server tokens. Sidebar RBAC driven by per-user permissions JSON or role defaults."
  },

  "directory_map": {
    "config/": "Central settings: DB URL, theme colors, role permissions, business-rule constants",
    "controllers/": "AppController — the single wiring point for the whole app",
    "database/": "SQLAlchemy engine, session factory, schema bootstrap & migrations",
    "models/": "All ORM table classes (21 tables)",
    "repositories/": "BaseRepository + 10 domain-specific repos",
    "services/": "9 service classes containing all business logic",
    "views/": "10 full-screen views + reusable widget library + theme constants",
    "reports/": "ReportGenerator (PDF/Excel) and PDFGenerator (receipts, prescriptions, CF2–CF5)",
    "utils/": "helpers, security (bcrypt + session), validators, rotating logger",
    "docs/": "USER_MANUAL.md, INSTALLATION.md",
    "assets/": "Runtime directory (auto-created) for images/logos",
    "logs/": "Rotating log file clinic.log",
    "backups/": "mysqldump output directory",
    "eclaims/": "PhilHealth eClaims ZIP packages",
    "uploads/": "Patient photo uploads"
  },

  "database_schema": {
    "database_name": "clinic_management",
    "charset": "utf8mb4_unicode_ci",
    "bootstrap": "Programmatic via SQLAlchemy Base.metadata.create_all() on startup, or manual via database/schema.sql",
    "tables": [
      {
        "name": "roles",
        "model": "models/user.py → Role",
        "key_fields": ["id", "name (unique)", "description", "permissions (JSON)", "created_at", "updated_at"],
        "relationships": ["1:N → users"]
      },
      {
        "name": "users",
        "model": "models/user.py → User",
        "key_fields": ["id", "role_id (FK→roles)", "username (unique)", "password_hash", "full_name", "email", "phone", "is_active", "permissions (JSON, override)", "last_login", "created_at", "updated_at"],
        "relationships": ["N:1 → roles", "1:N → appointments (doctor)", "1:N → consultations (doctor)"]
      },
      {
        "name": "patients",
        "model": "models/patient.py → Patient",
        "key_fields": ["id", "patient_number (unique, PAT-YYYY-#####)", "first_name", "middle_name", "last_name", "suffix", "birth_date", "gender", "civil_status", "contact_number", "email", "address_street/city/province/zip", "emergency contact fields", "philhealth_number", "philhealth_category", "philhealth_member_type", "is_senior_citizen", "senior_id_number", "is_pwd", "pwd_id_number", "photo_path", "notes", "is_archived", "timestamps"],
        "computed_properties": ["full_name", "full_address"],
        "relationships": ["1:N → appointments", "1:N → consultations", "1:N → billings", "1:N → philhealth_transactions"]
      },
      {
        "name": "appointments",
        "model": "models/appointment.py → Appointment",
        "key_fields": ["id", "patient_id (FK)", "doctor_id (FK→users, nullable)", "appointment_date", "appointment_time", "reason", "status (Scheduled|Confirmed|Completed|Cancelled|No Show)", "notes", "created_by (FK→users)", "timestamps"],
        "relationships": ["N:1 → patients", "N:1 → users (doctor)"]
      },
      {
        "name": "consultations",
        "model": "models/consultation.py → Consultation",
        "key_fields": ["id", "patient_id", "doctor_id", "appointment_id (nullable)", "consultation_date", "chief_complaint", "vital_signs (JSON: bp/hr/temp/weight)", "diagnosis", "treatment_plan", "doctor_notes", "follow_up_date", "status (In Progress|Completed|Cancelled)", "timestamps"],
        "relationships": ["N:1 → patients", "N:1 → users (doctor)", "1:N → prescriptions"]
      },
      {
        "name": "prescriptions",
        "model": "models/prescription.py → Prescription",
        "key_fields": ["id", "consultation_id", "patient_id", "doctor_id", "prescription_date", "doctor_signature", "notes", "created_at"],
        "relationships": ["N:1 → consultations", "1:N → prescription_items (cascade delete)"]
      },
      {
        "name": "prescription_items",
        "model": "models/prescription.py → PrescriptionItem",
        "key_fields": ["id", "prescription_id", "medicine_id (nullable)", "medicine_name", "dosage", "frequency", "duration", "quantity", "instructions"]
      },
      {
        "name": "medicine_categories",
        "model": "models/medicine.py → MedicineCategory",
        "key_fields": ["id", "name (unique)", "description", "created_at"],
        "relationships": ["1:N → medicines"]
      },
      {
        "name": "suppliers",
        "model": "models/medicine.py → Supplier",
        "key_fields": ["id", "name", "contact_person", "phone", "email", "address", "created_at"],
        "relationships": ["1:N → medicines"]
      },
      {
        "name": "medicines",
        "model": "models/medicine.py → Medicine",
        "key_fields": ["id", "category_id", "supplier_id", "generic_name", "brand_name", "dosage_form", "strength", "unit_price", "selling_price", "stock_quantity", "reorder_level", "batch_number", "expiration_date", "is_active", "timestamps"],
        "computed_properties": ["display_name"],
        "relationships": ["N:1 → medicine_categories", "N:1 → suppliers", "1:N → inventory_transactions"]
      },
      {
        "name": "inventory_transactions",
        "model": "models/medicine.py → InventoryTransaction",
        "key_fields": ["id", "medicine_id", "transaction_type (Stock In|Stock Out|Adjustment|Dispensed)", "quantity", "batch_number", "expiration_date", "unit_cost", "reference_number", "notes", "performed_by", "created_at"]
      },
      {
        "name": "billings",
        "model": "models/billing.py → Billing",
        "key_fields": ["id", "billing_number (unique, BIL-YYYY-#####)", "patient_id", "consultation_id (nullable)", "subtotal", "discount_amount", "discount_type", "philhealth_deduction", "total_amount", "amount_paid", "balance", "payment_status (Unpaid|Partial|Paid|Cancelled)", "notes", "created_by", "timestamps"],
        "relationships": ["N:1 → patients", "1:N → billing_items (cascade)", "1:N → payments"]
      },
      {
        "name": "billing_items",
        "model": "models/billing.py → BillingItem",
        "key_fields": ["id", "billing_id", "item_type (Consultation|Medicine|Procedure|Other)", "description", "quantity", "unit_price", "total_price", "medicine_id (nullable)"]
      },
      {
        "name": "payments",
        "model": "models/billing.py → Payment",
        "key_fields": ["id", "billing_id", "amount", "payment_method (Cash|Check|Bank Transfer|GCash|Other)", "receipt_number (OR-YYYYMMDDHHMMSS-XXXX)", "notes", "received_by", "payment_date"]
      },
      {
        "name": "philhealth_records",
        "model": "models/philhealth.py → PhilHealthRecord",
        "key_fields": ["id", "case_code (unique)", "case_description", "case_rate (₱)", "hospital_share_pct (default 70)", "professional_fee_pct (default 30)", "is_active", "timestamps"],
        "seeded_defaults": [
          {"code": "ACR001", "desc": "Acute Gastroenteritis", "rate": 6000},
          {"code": "PN001",  "desc": "Community Acquired Pneumonia", "rate": 15000},
          {"code": "UTI001", "desc": "Urinary Tract Infection", "rate": 6000},
          {"code": "HTN001", "desc": "Hypertension Package", "rate": 9000},
          {"code": "DM001",  "desc": "Diabetes Mellitus Package", "rate": 9000}
        ]
      },
      {
        "name": "philhealth_transactions",
        "model": "models/philhealth.py → PhilHealthTransaction",
        "key_fields": ["id", "patient_id", "billing_id", "consultation_id", "case_rate_id", "philhealth_number", "case_rate_amount", "hospital_share", "professional_fee", "philhealth_deduction", "patient_balance", "senior_discount", "pwd_discount", "total_bill", "notes", "processed_by", "transaction_date"]
      },
      {
        "name": "philhealth_claim_forms",
        "model": "models/philhealth.py → PhilHealthClaimForm",
        "key_fields": ["form_number", "form_type (CF2|CF3|CF4|CF5)", "status (Draft|Submitted|Approved|Rejected)", "patient_id", "transaction_id", "common claim fields", "type-specific fields (admission, physician, dialysis)", "eclaim_ref_no", "eclaim_submitted_at", "eclaim_status", "supporting_docs", "eclaim_notes", "timestamps"]
      },
      {
        "name": "clinic_settings",
        "model": "models/settings_model.py → ClinicSettings",
        "key_fields": ["id", "clinic_name", "clinic_address", "clinic_phone", "clinic_email", "clinic_logo_path", "receipt_header", "receipt_footer", "consultation_fee (default 500)", "tax_id", "philhealth_accreditation", "updated_at"]
      },
      {
        "name": "activity_logs",
        "model": "models/audit.py → ActivityLog",
        "key_fields": ["id", "user_id", "action", "module", "description", "ip_address", "created_at"]
      },
      {
        "name": "audit_logs",
        "model": "models/audit.py → AuditLog",
        "key_fields": ["id", "user_id", "table_name", "record_id", "action (CREATE|UPDATE|DELETE)", "old_values (JSON)", "new_values (JSON)", "created_at"]
      }
    ]
  },

  "models_reference": {
    "import_all_from": "models/__init__.py",
    "note": "PhilHealthClaimForm is defined in models/philhealth.py but NOT re-exported via __init__.py — import directly when needed"
