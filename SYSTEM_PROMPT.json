  "philhealth_deep_dive": {
    "overview": "Deep Philippine PhilHealth integration for clinic billing workflows",
    "case_rates": "Standardized reimbursement amounts per diagnosis code. Seeded with 5 defaults; expandable via UI.",
    "benefit_computation_flow": [
      "1. Select patient + case rate + total bill amount",
      "2. Compute hospital_share = case_rate × 0.70",
      "3. Compute professional_fee = case_rate × 0.30",
      "4. philhealth_deduction = min(case_rate, total_bill)",
      "5. patient_balance = total_bill - philhealth_deduction",
      "6. Apply senior or PWD 20% discount to patient_balance (non-cumulative)",
      "7. Persist PhilHealthTransaction; optionally apply deduction to linked Billing"
    ],
    "claim_forms": {
      "CF2": "Hospital/Facility Claim — admission dates, diagnoses, itemized charges",
      "CF3": "Professional Fee Claim — physician PRC/PTR/PhilHealth numbers, professional fees",
      "CF4": "Outpatient/All Case Rates — general outpatient claims",
      "CF5": "ESRD/Dialysis Claim — dialysis sessions, period, center accreditation number"
    },
    "claim_status_workflow": "Draft → Submitted → Approved | Rejected",
    "eclaims_workflow": [
      "1. Attach supporting PDF documents via _EClaimTransmitDialog",
      "2. Auto-generate claim form PDF via PDFGenerator",
      "3. Bundle manifest.json + all docs into ZIP at eclaims/{form_number}.zip",
      "4. Record eclaim_ref_no (ECLAIM-YYYYMMDDHHMMSS-####), eclaim_submitted_at",
      "5. Update status to Transmitted",
      "6. Track subsequent Acknowledged/Rejected status via eClaims Log tab"
    ]
  },

  "application_startup_flow": [
    "clinic.bat (Windows) checks Python, installs deps, runs setup_db.py",
    "main.py: ClinicApplication.__init__ creates CTk root window",
    "AppController.__init__: creates SQLAlchemy session, instantiates all services",
    "AppController.initialize_database(): init_db() → Base.metadata.create_all() → _migrate_schema()",
    "AppController.initialize_database(): seed roles → seed admin → seed PhilHealth rates → commit",
    "main.py: show_login() → renders LoginView",
    "On login: AuthService.login → commit → MainAppView created → 9 views registered with injected services",
    "User navigates via RBAC-filtered sidebar → show_view(key) → view.refresh()",
    "on_closing: controller.close() → session.close()"
  ],

  "conventions_and_patterns": {
    "id_generation": {
      "patient_number": "PAT-{YYYY}-{seq:05d} — generated in PatientRepository.get_next_number()",
      "billing_number": "BIL-{YYYY}-{seq:05d} — generated in BillingRepository.get_next_number()",
      "form_number": "auto-generated in PhilHealthService._generate_form_number(form_type)",
      "receipt_number": "OR-{YYYYMMDDHHMMSS}-{XXXX} — utils/security.generate_receipt_number()",
      "eclaim_ref": "ECLAIM-{YYYYMMDDHHMMSS}-{####}"
    },
    "session_commits": "Services use session.flush() for intra-transaction visibility; AppController.commit() or get_db_session() context manager for final commit",
    "soft_delete": "Patients use is_archived=True; other entities use is_active flags",
    "audit_trail": "PatientService writes to audit_logs on CREATE/UPDATE; AuthService writes to activity_logs on login/logout",
    "vital_signs_storage": "Stored as JSON dict {bp, hr, temperature, weight} on consultations.vital_signs",
    "permissions_storage": "JSON array of page keys on users.permissions (overrides) or roles.permissions (defaults)",
    "rbac_resolution": "AuthService.resolve_permissions(user) → uses user.permissions if set, else role defaults from ROLE_PERMISSIONS config"
  },

  "known_extension_points": {
    "add_new_view": [
      "1. Create views/new_feature_view.py with a CTkFrame subclass and optional refresh() method",
      "2. Add service injection parameter to __init__",
      "3. Register in main.py: controller.register_views({'new_feature': NewFeatureView(...)})",
      "4. Add nav item to MainAppView sidebar nav_items list",
      "5. Add page key to config/settings.py PAGE_PERMISSIONS and ROLE_PERMISSIONS"
    ],
    "add_new_service": [
      "1. Create services/new_service.py with NewService class",
      "2. Accept session in __init__, instantiate needed repositories",
      "3. Add to AppController._init_services() as self.new_feature = NewService(self.session)",
      "4. Inject into relevant views via main.py registration"
    ],
    "add_new_model": [
      "1. Create models/new_model.py with SQLAlchemy ORM class extending Base",
      "2. Export from models/__init__.py",
      "3. Re-run init_db() or add migration to database/connection._migrate_schema()",
      "4. Create corresponding repository in repositories/"
    ],
    "add_new_report": [
      "1. Add report type key to reports/report_generator.py _get_data() and _row_values()",
      "2. Add UI card in views/reports_view.py report definitions list"
    ],
    "add_philhealth_case_rate": "Via UI (PhilHealth → Benefit Computation tab) or directly insert into philhealth_records table"
  },

  "common_gotchas": {
    "PhilHealthClaimForm_import": "models/philhealth.py → PhilHealthClaimForm is NOT in models/__init__.py; import directly: from models.philhealth import PhilHealthClaimForm",
    "session_sharing": "All services share one session via AppController. Avoid creating new sessions inside services.",
    "bcrypt_cost": "Hash operations are intentionally slow. Do not call hash_password() in a tight loop.",
    "db_bootstrap": "Running main.py without first running setup_db.py (or having MySQL running) will raise a connection error at init_db().",
    "permissions_json": "users.permissions is nullable. A NULL value means 'use role defaults'. An empty list [] means 'no access'.",
    "vital_signs_json": "consultations.vital_signs is a JSON column. Always serialize/deserialize as a dict.",
    "eclaims_zip_path": "ZIP output goes to eclaims/{form_number}.zip and contents to eclaims/{form_number}/. The eclaims/ dir is auto-created by config/settings.py on import."
  },

